<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Index</title>
  </head>
  <body>
    <h1>Mini Message Board</h1>
    <section>
      <ul>
        <% for (let i = 0; i < messages.length; i++) { %>
        <li>
          <a href="<%= messages[i].text %>"></a>
        </li>
        <% } %>
      </ul>
    </section>
    <button>Add new message</button>
  </body>
</html>
